{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "jsx": "react",
    "outDir": "./src/main/resources/static/js",
    "rootDir": "./src",
    "noEmit": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strict": true,
    "moduleResolution": "node",
    "removeComments": true,
    "sourceMap": true,
    "allowJs": true,
    "checkJs": false,
    "outFile": "./src/main/resources/static/js/bundle.js"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "src/main/resources", "dist", "build"]
}